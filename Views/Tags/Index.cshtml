@model List<RequestTag>

@{
    ViewData["Title"] = ViewData["Title"] ?? "Tags";
    var newTag = new RequestTag { ColorHex = "#13D0D4", CreatedAt = DateTime.Now };
}

<nav class="page-crumbs" aria-label="Breadcrumb">
    <a asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-area="" asp-controller="Request" asp-action="Index">Requests</a>
    <span>/</span>
    <strong>Tags</strong>
</nav>

<section class="details-hero">
    <div>
        <p class="details-kicker">Tag Registry</p>
        <h1>Request Tags</h1>
        <p>Create and tune the labels used to group requests.</p>
    </div>
    <div class="details-hero-actions">
        <a class="btn app-btn app-btn-muted" asp-area="" asp-controller="Request" asp-action="Index">Back to Requests</a>
    </div>
</section>

<section class="details-grid">
    <div class="detail-panel">
        <div class="panel-title-row">
            <h3>New Tag</h3>
        </div>
        <form asp-controller="Tags" asp-action="Save" method="post" class="nested-crud-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <label class="runner-field">
                <span>Name</span>
                <input name="Name" class="form-control" required maxlength="80" />
                <span data-valmsg-for="Name" class="text-danger"></span>
            </label>
            <label class="runner-field">
                <span>Color</span>
                <input name="ColorHex" type="color" class="form-control form-control-color" value="@newTag.ColorHex" />
                <span data-valmsg-for="ColorHex" class="text-danger"></span>
            </label>
            <label class="runner-field">
                <span>Created</span>
                <partial name="_DateTimePicker" model="@(new API_tester.Models.DateTimePickerModel {
                    InputId = "newTagCreatedAt",
                    InputName = "CreatedAt",
                    Value = newTag.CreatedAt,
                    Placeholder = "Date and time",
                    Required = true
                })" />
            </label>
            <button type="submit" class="btn app-btn app-btn-primary mt-2">Create Tag</button>
        </form>
    </div>

    <div class="detail-panel">
        <div class="panel-title-row">
            <h3>Tag Search</h3>
        </div>
        <div class="request-search">
            <label for="tagSearch">Search</label>
            <input id="tagSearch" type="text" placeholder="Search tags" />
        </div>
    </div>
</section>

<section class="detail-panel mt-3">
    <div class="panel-title-row">
        <h3>Existing Tags</h3>
    </div>
    <div class="tag-list" id="tagList">
        @foreach (var tag in Model)
        {
            <article class="tag-row">
                <form asp-controller="Tags" asp-action="Save" method="post" class="nested-row">
                    @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@tag.Id" />
                <input name="Name" class="form-control" value="@tag.Name" required maxlength="80" />
                <span data-valmsg-for="Name" class="text-danger"></span>
                <input name="ColorHex" type="color" class="form-control form-control-color" value="@tag.ColorHex" />
                <span data-valmsg-for="ColorHex" class="text-danger"></span>
                    <partial name="_DateTimePicker" model="@(new API_tester.Models.DateTimePickerModel {
                        InputId = $"tagCreatedAt{tag.Id}",
                        InputName = "CreatedAt",
                        Value = tag.CreatedAt == default ? DateTime.Now : tag.CreatedAt,
                        Placeholder = "Date and time",
                        Required = true
                    })" />
                    <button type="submit" class="btn app-btn app-btn-muted">Save</button>
                </form>
                <form asp-controller="Tags" asp-action="Delete" asp-route-id="@tag.Id" method="post" class="nested-delete-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn app-btn app-btn-danger">Delete @tag.Name</button>
                </form>
            </article>
        }
    </div>
</section>
