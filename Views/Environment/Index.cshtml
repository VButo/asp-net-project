@model IEnumerable<ApiEnvironment>

@{
    ViewData["Title"] = ViewData["Title"] ?? "Environments";
    var breadcrumbCurrent = ViewData["BreadcrumbCurrent"] as string ?? "Environments";
    var heroKicker = ViewData["HeroKicker"] as string ?? string.Empty;
    var heroTitle = ViewData["HeroTitle"] as string ?? string.Empty;
    var heroDescription = ViewData["HeroDescription"] as string ?? string.Empty;
    var primaryActionText = ViewData["PrimaryActionText"] as string ?? string.Empty;
    var secondaryActionText = ViewData["SecondaryActionText"] as string ?? string.Empty;
}

<nav class="page-crumbs" aria-label="Breadcrumb">
    <a asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-area="" asp-controller="Workspaces" asp-action="Index">Workspaces</a>
    <span>/</span>
    <a asp-area="" asp-controller="Environment" asp-action="Index">Environments</a>
    <span>/</span>
    <strong>@breadcrumbCurrent</strong>
</nav>

<section class="details-hero">
    <div>
        <p class="details-kicker">@heroKicker</p>
        <h1>@heroTitle</h1>
        <p>@heroDescription</p>
    </div>
    <div class="details-hero-actions">
        <button type="button" class="btn app-btn app-btn-primary" data-bs-toggle="modal" data-bs-target="#environmentCreateModal">New Environment</button>
        <a class="btn app-btn app-btn-primary" asp-area="" asp-controller="RequestBuilder" asp-action="Index">@primaryActionText</a>
        <a class="btn app-btn app-btn-muted" asp-area="" asp-controller="Workspaces" asp-action="Index">@secondaryActionText</a>
    </div>
</section>

<section class="detail-panel">
    <div class="panel-title-row">
        <h3>Environment List</h3>
        <a asp-area="" asp-controller="RequestBuilder" asp-action="Index">Run Request</a>
    </div>
    <section class="environment-toolbar" aria-label="Environment filters">
        <div class="environment-search">
            <label for="environmentSearch">Search</label>
            <input id="environmentSearch" type="text" value="" placeholder="Search environments" />
        </div>
    </section>
    <ul class="panel-list mono">
        @foreach (var environment in Model)
        {
            <li>
                <strong>@environment.Name</strong>
                <span>@environment.BaseUrl</span>
                <a class="entity-link" asp-area="" asp-controller="RequestBuilder" asp-action="Index">Use in Builder</a>
                <a href="#" class="entity-link open-environment-edit" data-environment-id="@environment.Id">Edit</a>
                <a href="#" class="entity-link open-environment-delete" data-environment-id="@environment.Id">Delete</a>
            </li>
        }
    </ul>
</section>

<div class="modal fade" id="environmentCreateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content collection-modal">
            <div class="modal-header collection-modal-header">
                <div>
                    <p class="collection-modal-kicker">Environments</p>
                    <h5 class="modal-title">New Environment</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body collection-modal-body">
                <partial name="_EnvironmentEdit" model="@(new API_tester.Models.ApiEnvironment { IsActive = true })" />
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="environmentEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Environment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">Loading…</div>
        </div>
    </div>
</div>

<div class="modal fade" id="environmentDeleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Environment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this environment?</p>
            </div>
            <div class="modal-footer">
                <form id="environmentDeleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn app-btn app-btn-muted" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn app-btn app-btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('.open-environment-edit').on('click', function (e) {
                e.preventDefault();
                var id = $(this).data('environment-id');
                var url = '/Environment/edit/' + id;
                $.get(url, function (html) {
                    if (window.injectModalHtml) window.injectModalHtml('#environmentEditModal .modal-body', html);
                    else { $('#environmentEditModal .modal-body').html(html); var modalEl = document.getElementById('environmentEditModal'); if (modalEl && window.bootstrap) { var modal = new bootstrap.Modal(modalEl); modal.show(); } }
                }).fail(function () { alert('Failed to load edit form'); });
            });

            $('.open-environment-delete').on('click', function (e) {
                e.preventDefault();
                var id = $(this).data('environment-id');
                var form = $('#environmentDeleteForm');
                form.attr('action', '/environments/delete/' + id);
                var modalEl = document.getElementById('environmentDeleteModal');
                if (modalEl && window.bootstrap) {
                    var modal = new bootstrap.Modal(modalEl);
                    modal.show();
                }
            });

            $('#environmentDeleteForm').on('submit', function (e) {
                e.preventDefault();
                var action = $(this).attr('action');
                var token = $(this).find('input[name="__RequestVerificationToken"]').val();
                $.post(action, { __RequestVerificationToken: token })
                    .done(function () { location.reload(); })
                    .fail(function () { alert('Failed to delete environment'); });
            });
        });
    </script>
}
