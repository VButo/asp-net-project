<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - API Tester</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/API_tester.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-background"></div>

    <header class="app-header">
        <nav class="app-nav container">
            <a class="app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="app-brand-icon">AT</span>
                <span class="app-brand-text">API Tester</span>
            </a>

            <button class="navbar-toggler app-menu-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#appMenu" aria-controls="appMenu"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse app-menu" id="appMenu">
                <ul class="app-links">
                    <li><a asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a></li>
                    <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Docs</a></li>
                    <li><a href="#">History</a></li>
                </ul>
                <div class="app-nav-actions">
                    <a class="btn app-btn app-btn-muted" href="#">Import</a>
                    <a class="btn app-btn app-btn-primary" href="#">New Request</a>
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-shell">
        <main role="main" class="app-main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container app-footer-inner">
            <span>&copy; 2026 API Tester</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
