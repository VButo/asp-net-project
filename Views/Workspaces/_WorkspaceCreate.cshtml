@model API_tester.Models.ApiWorkspace

<form asp-area="" asp-controller="Workspaces" asp-action="Create" method="post" class="workspace-create-form collection-modal-form">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="collection-modal-grid">
        <div class="mb-3 collection-modal-span-2">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3 collection-modal-span-2">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
    </div>

    <div class="modal-footer collection-modal-footer">
        <button type="button" class="btn app-btn app-btn-muted" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn app-btn app-btn-primary">Create Workspace</button>
    </div>
</form>
