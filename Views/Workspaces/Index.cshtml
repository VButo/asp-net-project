@model List<ApiWorkspace>
@using API_tester.Models

@{
    var heroKicker = ViewData["HeroKicker"] as string ?? string.Empty;
    var heroTitle = ViewData["HeroTitle"] as string ?? string.Empty;
    var heroDescription = ViewData["HeroDescription"] as string ?? string.Empty;
    var primaryActionText = ViewData["PrimaryActionText"] as string ?? string.Empty;
    var searchPlaceholder = ViewData["SearchPlaceholder"] as string ?? string.Empty;
}

<nav class="page-crumbs" aria-label="Breadcrumb">
    <a asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <strong>Workspaces</strong>
</nav>

<section class="workspaces-hero">
    <div class="workspaces-hero-copy">
        <p class="workspaces-kicker">@heroKicker</p>
        <h1>@heroTitle</h1>
        <p>@heroDescription</p>
    </div>
    <div class="workspaces-hero-actions">
        <button type="button" class="btn app-btn app-btn-primary" data-bs-toggle="modal" data-bs-target="#workspaceCreateModal">@primaryActionText</button>
    </div>
</section>

<section class="workspaces-toolbar" aria-label="Workspace filters">
    <div class="workspace-search">
        <label for="workspaceSearch">Search</label>
        <input id="workspaceSearch" type="text" value="" placeholder="@searchPlaceholder" />
    </div>
</section>

<section class="workspaces-grid" aria-label="Workspace list">
    @foreach (var workspace in Model)
    {
        <article class="workspace-card">
            <div class="workspace-head">
                <h2>@workspace.Name</h2>
            </div>
            <p class="workspace-description">@workspace.Description</p>
            <div class="workspace-metrics">
                <p><span>Collections</span><strong>@workspace.Collections.Count</strong></p>
                <p><span>Environments</span><strong>@workspace.Environments.Count</strong></p>
            </div>
            <a href="#" class="entity-link open-workspace-details" data-workspace-id="@workspace.Id">Open Workspace Details</a>
            <a href="#" class="entity-link open-workspace-edit" data-workspace-id="@workspace.Id">Edit</a>
            <a href="#" class="entity-link open-workspace-delete" data-workspace-id="@workspace.Id">Delete</a>
        </article>
    }
</section>

<div class="modal fade" id="workspaceCreateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg collection-modal-dialog">
        <div class="modal-content collection-modal">
            <div class="modal-header collection-modal-header">
                <div>
                    <p class="collection-modal-kicker">Workspaces</p>
                    <h5 class="modal-title">New Workspace</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
                <div class="modal-body collection-modal-body">
                    <partial name="_WorkspaceCreate" model="@(new API_tester.Models.ApiWorkspace())" />
                </div>
        </div>
    </div>
</div>

            <div class="modal fade" id="workspaceEditModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Edit Workspace</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">Loading…</div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="workspaceDeleteModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Delete Workspace</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p>Are you sure you want to delete this workspace?</p>
                        </div>
                        <div class="modal-footer">
                            <form id="workspaceDeleteForm" method="post">
                                @Html.AntiForgeryToken()
                                <button type="button" class="btn app-btn app-btn-muted" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn app-btn app-btn-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

<div class="modal fade" id="workspaceDetailsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Workspace Details</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">Loading…</div>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#workspaceCreateModal').on('shown.bs.modal', function () {
                $('#workspaceName').trigger('focus');
            });

            $('.open-workspace-details').on('click', function (e) {
                e.preventDefault();
                var id = $(this).data('workspace-id');
                var url = '/workspace-details?workspaceId=' + id;
                $.get(url, function (html) {
                    if (window.injectModalHtml) window.injectModalHtml('#workspaceDetailsModal .modal-body', html);
                    else { $('#workspaceDetailsModal .modal-body').html(html); var modalEl = document.getElementById('workspaceDetailsModal'); if (modalEl && window.bootstrap) { var modal = new bootstrap.Modal(modalEl); modal.show(); } }
                }).fail(function () {
                    alert('Failed to load workspace details');
                });
            });

            $('.open-workspace-edit').on('click', function (e) {
                e.preventDefault();
                var id = $(this).data('workspace-id');
                var url = '/workspaces/edit/' + id;
                $.get(url, function (html) {
                    if (window.injectModalHtml) window.injectModalHtml('#workspaceEditModal .modal-body', html);
                    else { $('#workspaceEditModal .modal-body').html(html); var modalEl = document.getElementById('workspaceEditModal'); if (modalEl && window.bootstrap) { var modal = new bootstrap.Modal(modalEl); modal.show(); } }
                }).fail(function () {
                    alert('Failed to load edit form');
                });
            });

            $('.open-workspace-delete').on('click', function (e) {
                e.preventDefault();
                var id = $(this).data('workspace-id');
                var form = $('#workspaceDeleteForm');
                form.attr('action', '/Workspaces/delete/' + id);
                var modalEl = document.getElementById('workspaceDeleteModal');
                if (modalEl && window.bootstrap) {
                    var modal = new bootstrap.Modal(modalEl);
                    modal.show();
                }
            });

            $('#workspaceDeleteForm').on('submit', function (e) {
                e.preventDefault();
                var action = $(this).attr('action');
                var token = $(this).find('input[name="__RequestVerificationToken"]').val();
                $.post(action, { __RequestVerificationToken: token })
                    .done(function () { location.reload(); })
                    .fail(function () { alert('Failed to delete workspace'); });
            });
        });
    </script>
}
