@model API_tester.Models.ApiWorkspace

<form id="workspaceEditForm" asp-controller="Workspaces" asp-action="Edit" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="collection-modal-note mb-3">
    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn app-btn app-btn-muted" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn app-btn app-btn-primary">Save</button>
    </div>
</form>
