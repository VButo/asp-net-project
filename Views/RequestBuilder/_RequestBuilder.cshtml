@model API_tester.Models.ApiRequest
@using API_tester.Models

@{
    var selectedMethod = Model.Method;
    var collections = ViewBag.Collections as IEnumerable<ApiCollection> ?? Enumerable.Empty<ApiCollection>();
    var selectedEnvironment = Model.EnvironmentLinks.FirstOrDefault(link => link.IsDefaultEnvironment)?.Environment
        ?? Model.EnvironmentLinks.FirstOrDefault()?.Environment;
    var selectedTag = Model.TagLinks.FirstOrDefault()?.Tag;
    var headers = Model.Headers.Any()
        ? Model.Headers.OrderBy(h => h.Id).ToList()
        : new List<ApiHeader> { new ApiHeader { IsEnabled = true } };
}

<form id="requestBuilderForm" class="request-builder-form" asp-area="" asp-controller="RequestBuilder" asp-action="Save" method="post" data-ajax-validation="true">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <section class="runner-request-head" aria-label="HTTP request setup">
        <label class="runner-field" for="requestName">
            <span>Request Name</span>
            <input asp-for="Name" id="requestName" class="form-control" placeholder="Request name" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </label>

        <div class="runner-method-url">
            <label class="runner-field" for="requestMethod">
                <span>Method</span>
                <select asp-for="Method" id="requestMethod" class="form-select">
                    @foreach (var method in Enum.GetValues(typeof(API_tester.Models.Enums.HttpMethodType)).Cast<API_tester.Models.Enums.HttpMethodType>())
                    {
                        if (method == selectedMethod)
                        {
                            <option value="@method" selected="selected">@method.ToString().ToUpperInvariant()</option>
                        }
                        else
                        {
                            <option value="@method">@method.ToString().ToUpperInvariant()</option>
                        }
                    }
                </select>
                <span asp-validation-for="Method" class="text-danger"></span>
            </label>

            <label class="runner-field runner-url-field" for="requestUrl">
                <span>Request URL</span>
                <input asp-for="Url" id="requestUrl" class="form-control" placeholder="https://api.example.com/v1/resource" />
                <span asp-validation-for="Url" class="text-danger"></span>
            </label>
        </div>

        <label class="runner-field" for="requestCollectionInput">
            <span>Collection</span>
            <partial name="_Autocomplete" model="@(new API_tester.Models.AutocompleteModel {
                InputId = "requestCollectionInput",
                HiddenId = "CollectionId",
                SearchUrl = "/collections/search",
                SelectedId = Model.CollectionId,
                SelectedText = Model.Collection?.Name ?? string.Empty,
                Placeholder = "Search collections..."
            })" />
            <span asp-validation-for="CollectionId" class="text-danger"></span>
        </label>

        <div class="runner-controls-row">
            <label class="runner-field runner-env-field" for="requestEnvironmentInput">
                <span>Environment</span>
                <partial name="_Autocomplete" model="@(new API_tester.Models.AutocompleteModel {
                    InputId = "requestEnvironmentInput",
                    HiddenId = "EnvironmentId",
                    SearchUrl = "/environments/search",
                    SelectedId = selectedEnvironment?.Id ?? 0,
                    SelectedText = selectedEnvironment?.Name ?? string.Empty,
                    Placeholder = "Search environments..."
                })" />
            </label>

            <label class="runner-field runner-env-field" for="requestTagInput">
                <span>Tag</span>
                <partial name="_Autocomplete" model="@(new API_tester.Models.AutocompleteModel {
                    InputId = "requestTagInput",
                    HiddenId = "TagId",
                    SearchUrl = "/tags/search",
                    SelectedId = selectedTag?.Id ?? 0,
                    SelectedText = selectedTag?.Name ?? string.Empty,
                    Placeholder = "Search tags..."
                })" />
            </label>

            <div class="builder-request-actions">
                <button type="submit" class="runner-send-btn">Save Request</button>
                @if (Model.Id > 0)
                {
                    <button type="submit" class="runner-send-btn runner-run-btn" formaction="/request-builder/run/@Model.Id" formmethod="post">Run Request</button>
                }
                <button type="button" class="builder-secondary-btn" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>

        <div class="runner-jump-links">
            <a asp-area="" asp-controller="Request" asp-action="Index">View Requests</a>
            <a asp-area="" asp-controller="Collection" asp-action="Index">Pick Collection</a>
            <a asp-area="" asp-controller="Environment" asp-action="Index">Manage Environments</a>
        </div>
    </section>

    <section class="runner-editor-panel" aria-label="Request editors">
        <div class="runner-tab-strip">
            <button type="button" class="runner-tab active" data-runner-tab="headers">Headers</button>
            <button type="button" class="runner-tab" data-runner-tab="body">Body</button>
            <button type="button" class="runner-tab" data-runner-tab="auth">Auth</button>
            <button type="button" class="runner-tab" data-runner-tab="tests">Tests</button>
        </div>

        <div class="runner-editors">
            <article class="editor-card runner-tab-pane active" data-runner-pane="headers">
                <header>
                    <h2>Headers</h2>
                    <span>@headers.Count(h => h.IsEnabled) active</span>
                </header>
                <div class="nested-search header-search">
                    <label for="headerSearch">Search Headers</label>
                    <input id="headerSearch" class="nested-filter-input" type="text" data-filter-target="#headerEditorList" data-filter-row=".header-editor-row" placeholder="Search key or value" />
                </div>
                <div class="header-editor-list" id="headerEditorList">
                    @for (var i = 0; i < headers.Count; i++)
                    {
                        <div class="header-editor-row">
                            <input type="hidden" name="Headers[@i].Id" value="@headers[i].Id" />
                            <input type="hidden" name="Headers[@i].RequestId" value="@Model.Id" />
                            <input name="Headers[@i].Key" class="form-control" value="@headers[i].Key" placeholder="Header key" maxlength="150" />
                            <input name="Headers[@i].Value" class="form-control" value="@headers[i].Value" placeholder="Header value" maxlength="2000" />
                            <label class="form-check">
                                <input name="Headers[@i].IsEnabled" value="true" type="checkbox" class="form-check-input" checked="@headers[i].IsEnabled" />
                                <input name="Headers[@i].IsEnabled" value="false" type="hidden" />
                                <span>On</span>
                            </label>
                            <button type="button" class="btn app-btn app-btn-muted remove-header-row">Remove</button>
                        </div>
                    }
                </div>
                <button type="button" class="btn app-btn app-btn-muted add-header-row" data-next-index="@headers.Count">Add Header</button>
            </article>

            <article class="editor-card body-card runner-tab-pane" data-runner-pane="body">
                <header>
                    <h2>Body (JSON)</h2>
                    <span>raw</span>
                </header>
                @{
                    var defaultBody = Model.Body ?? string.Empty;
                }
                <textarea asp-for="Body" rows="14" spellcheck="false" class="form-control">@Html.Raw(defaultBody)</textarea>
            </article>

            <article class="editor-card runner-tab-pane" data-runner-pane="auth">
                <header>
                    <h2>Auth</h2>
                    <span>headers</span>
                </header>
                <div class="empty-editor-pane">
                    Add auth values as request headers, for example <strong>Authorization</strong>.
                </div>
            </article>

            <article class="editor-card runner-tab-pane" data-runner-pane="tests">
                <header>
                    <h2>Tests</h2>
                    <span>notes</span>
                </header>
                <div class="empty-editor-pane">
                    Response history is available after running the request.
                </div>
            </article>
        </div>
    </section>

    @if (Model.Id > 0)
    {
        <section class="request-attachments-panel" data-request-id="@Model.Id" aria-label="Request attachments">
            <header>
                <div>
                    <p class="attachments-kicker">Attachments</p>
                    <h2>Request Files</h2>
                </div>
                <label class="btn app-btn app-btn-muted attachment-upload-label" for="requestAttachmentInput">
                    Upload
                    <input id="requestAttachmentInput" type="file" multiple data-request-id="@Model.Id" />
                </label>
            </header>
            <div class="request-attachment-status" aria-live="polite"></div>
            <div class="request-attachment-list" id="requestAttachmentList">
                <p class="text-muted">Loading attachments...</p>
            </div>
        </section>
    }
</form>
