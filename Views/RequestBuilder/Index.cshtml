@model API_tester.Models.ApiRequest

@{
    ViewData["Title"] = "Request Builder";
    var requestMethod = string.IsNullOrWhiteSpace(Model?.Url) ? "POST" : Model.Method.ToString().ToUpperInvariant();
    var requestUrl = string.IsNullOrWhiteSpace(Model?.Url) ? "https://staging.api.company.com/v1/notifications/dispatch" : Model.Url;
    var collectionName = Model?.Collection?.Name ?? "Notification Dispatch";
    var responseTitle = Model?.Responses.Any() == true ? "Latest Response" : "Sample Response";
}

<nav class="page-crumbs" aria-label="Breadcrumb">
    <a asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-area="" asp-controller="Workspaces" asp-action="Index">Workspaces</a>
    <span>/</span>
    <a asp-area="" asp-controller="Request" asp-action="Index">Requests</a>
    <span>/</span>
    <strong>Builder</strong>
</nav>

<section class="runner-hero" aria-label="Request builder intro">
    <div class="runner-hero-copy">
        <p class="runner-kicker">Request Builder / Runner</p>
        <h1>Konfiguriraj, pokreni i analiziraj API pozive iz jednog cockpit pogleda.</h1>
        <p>Glavni ekran za endpoint testiranje: metoda, URL, headers, body, environment i response panel bez prebacivanja izmedu stranica.</p>
    </div>
    <div class="runner-hero-stats">
        <p><span>Current Environment</span><strong>staging-eu</strong></p>
        <p><span>Target Collection</span><strong>@collectionName</strong></p>
        <p><span>Open Request</span><strong><a asp-area="" asp-controller="RequestDetails" asp-action="Details">@requestMethod @requestUrl</a></strong></p>
    </div>
</section>

<section class="runner-layout" aria-label="Request runner workspace">
    <div class="runner-left-panel">
        <div class="panel-title-row">
            <h3>Build Request</h3>
            <a asp-area="" asp-controller="Request" asp-action="Index">Back to Requests</a>
        </div>

        <partial name="_RequestBuilder" model="Model" />
    </div>

    <aside class="runner-right-panel" aria-label="Execution response">
        <div class="response-head">
            <h2>@responseTitle</h2>
            <p class="response-status success">202 Accepted · 121 ms · 1.3 KB</p>
        </div>

        <div class="response-meta">
            <p><span>Collection</span><strong><a asp-area="" asp-controller="Collection" asp-action="Details">@collectionName</a></strong></p>
            <p><span>Request</span><strong><a asp-area="" asp-controller="RequestDetails" asp-action="Details">@requestMethod @requestUrl</a></strong></p>
            <p><span>Executed At</span><strong>Today, 15:42:09</strong></p>
        </div>

        <div class="response-tabs">
            <button type="button" class="response-tab active">Body</button>
            <button type="button" class="response-tab">Headers</button>
            <button type="button" class="response-tab">Timeline</button>
        </div>

        <pre class="response-body">{
  "status": "queued",
  "messageId": "msg_43f9121",
  "channel": "email",
  "delivery": {
    "provider": "mailgun",
    "estimatedIn": "2s"
  },
  "meta": {
    "requestId": "req_aa12b9",
    "traceId": "tr_22f991"
  }
}</pre>

        <div class="runner-footer-links">
            <a asp-area="" asp-controller="RequestDetails" asp-action="Details">Open Full Response Context</a>
            <a asp-area="" asp-controller="Collection" asp-action="Details">Back to Collection</a>
            <a asp-area="" asp-controller="WorkspaceDetails" asp-action="Details">Back to Workspace</a>
        </div>
    </aside>
</section>
