@model List<ApiRequest>

@{
    ViewData["Title"] = ViewData["Title"] ?? "Requests";
    var breadcrumbCurrent = ViewData["BreadcrumbCurrent"] as string ?? "Requests";
    var heroKicker = ViewData["HeroKicker"] as string ?? string.Empty;
    var heroTitle = ViewData["HeroTitle"] as string ?? string.Empty;
    var heroDescription = ViewData["HeroDescription"] as string ?? string.Empty;
    var primaryActionText = ViewData["PrimaryActionText"] as string ?? string.Empty;
    var secondaryActionText = ViewData["SecondaryActionText"] as string ?? string.Empty;
    var searchPlaceholder = ViewData["SearchPlaceholder"] as string ?? string.Empty;
    var filters = ViewData["Filters"] as List<string> ?? new List<string>();
    var snapshotTitle = ViewData["SnapshotTitle"] as string ?? string.Empty;
    var successfulCount = ViewData["SuccessfulCount"] as int? ?? 0;
    var warningCount = ViewData["WarningCount"] as int? ?? 0;
    var notExecutedCount = ViewData["NotExecutedCount"] as int? ?? 0;
}

<nav class="page-crumbs" aria-label="Breadcrumb">
    <a asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-area="" asp-controller="Workspaces" asp-action="Index">Workspaces</a>
    <span>/</span>
    <a asp-area="" asp-controller="Collection" asp-action="Index">Collections</a>
    <span>/</span>
    <strong>@breadcrumbCurrent</strong>
</nav>

<section class="requests-hero" aria-label="Requests overview">
    <div class="requests-hero-copy">
        <p class="requests-kicker">@heroKicker</p>
        <h1>@heroTitle</h1>
        <p>@heroDescription</p>
    </div>
    <div class="requests-hero-actions">
        <a href="#" class="btn app-btn app-btn-primary open-request-builder" data-request-id="">@primaryActionText</a>
        <a class="btn app-btn app-btn-muted" asp-area="" asp-controller="RequestBuilder" asp-action="Index">@secondaryActionText</a>
    </div>
</section>

<section class="requests-commandbar" aria-label="Request controls">
    <div class="request-search">
        <label for="requestSearch">Search</label>
        <input id="requestSearch" type="text" placeholder="@searchPlaceholder" />
    </div>
    <div class="request-filter-group">
        @foreach (var filter in filters.Select((value, index) => new { value, index }))
        {
            <button class="request-chip @(filter.index == 0 ? "active" : string.Empty)" type="button">@filter.value</button>
        }
    </div>
</section>

<section class="requests-layout" aria-label="Requests list">
    <aside class="requests-side-rail" aria-label="Request summary">
        <p class="requests-rail-label">Live Snapshot</p>
        <h2>@snapshotTitle</h2>
        <ul>
            <li><span>Successful Latest Run</span><strong>@successfulCount</strong></li>
            <li><span>Warnings</span><strong>@warningCount</strong></li>
            <li><span>Not Executed</span><strong>@notExecutedCount</strong></li>
        </ul>
        @if (Model != null && Model.Any())
        {
            <a href="#" class="open-request-details" data-request-id="@Model.First().Id">Open Execution Timeline</a>
        }
        else
        {
            <a asp-area="" asp-controller="Request" asp-action="Index">Open Execution Timeline</a>
        }
    </aside>

    <div class="requests-stream">
        @{ var requests = Model ?? new List<ApiRequest>(); }
        @foreach (var request in requests)
        {
            var latestResponse = request.Responses.OrderByDescending(response => response.ReceivedAt).FirstOrDefault();
            var statusClass = latestResponse == null ? "idle" : latestResponse.IsSuccess ? "ok" : "warn";
            var statusText = latestResponse == null
                ? "Not executed yet"
                : $"{latestResponse.StatusCode} {(latestResponse.IsSuccess ? "OK" : "Conflict")} · {latestResponse.DurationMs} ms";

            <article class="request-row">
                <div class="request-main">
                    <span class="method-badge @(request.Method.ToString().ToLowerInvariant())">@request.Method.ToString().ToUpperInvariant()</span>
                    <div class="request-details">
                        <p class="request-url">@request.Url</p>
                        <p class="request-collection">Collection: @(request.Collection?.Name ?? string.Empty)</p>
                        <div class="request-tags">
                            @foreach (var tagName in request.TagLinks.Select(link => link.Tag?.Name).Where(name => !string.IsNullOrWhiteSpace(name)))
                            {
                                <span>@tagName</span>
                            }
                        </div>
                    </div>
                </div>
                <p class="request-last-run @statusClass">@statusText</p>
                <a href="#" class="entity-link open-request-details" data-request-id="@request.Id">Open Request Details</a>
            </article>
        }
    </div>

        <!-- Modal container for request builder -->
        <div class="modal fade" id="requestBuilderModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-xl request-builder-dialog">
                <div class="modal-content request-builder-modal">
                    <div class="modal-header request-builder-modal-header">
                        <h5 class="modal-title">Request Builder</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body request-builder-modal-body">Loading…</div>
                </div>
            </div>
        </div>
</section>

<!-- Modal container for request details -->
<div class="modal fade" id="requestDetailsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Request Details</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">Loading…</div>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('.open-request-details').on('click', function (e) {
                e.preventDefault();
                var id = $(this).data('request-id');
                if (!id) return;
                var url = '/RequestDetails/Details?requestId=' + id;
                $.get(url, function (html) {
                    $('#requestDetailsModal .modal-body').html(html);
                    var modalEl = document.getElementById('requestDetailsModal');
                    if (modalEl && window.bootstrap) {
                        var modal = new bootstrap.Modal(modalEl);
                        modal.show();
                    }
                }).fail(function () {
                    alert('Failed to load request details');
                });
            });

            // Open request builder modal (new or edit)
            $('.open-request-builder').on('click', function (e) {
                e.preventDefault();
                var id = $(this).data('request-id');
                var url = '@Url.Action("Index", "RequestBuilder")' + (id ? ('?requestId=' + id) : '');
                $.get(url, function (html) {
                    $('#requestBuilderModal .modal-body').html(html);
                    var modalEl = document.getElementById('requestBuilderModal');
                    if (modalEl && window.bootstrap) {
                        var modal = new bootstrap.Modal(modalEl);
                        modal.show();
                    }
                }).fail(function () {
                    alert('Failed to load request builder');
                });
            });
        });
    </script>
}