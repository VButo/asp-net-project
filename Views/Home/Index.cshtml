@model API_tester.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";

    var preview = Model.RequestPreview;
    var previewPath = "/requests";
    if (!string.IsNullOrWhiteSpace(preview?.Url) && Uri.TryCreate(preview.Url, UriKind.Absolute, out var previewUri))
    {
        previewPath = previewUri.PathAndQuery;
    }

    var previewBody = string.IsNullOrWhiteSpace(preview?.Body)
        ? "{\n  \"savedRequests\": " + Model.TotalRequests + ",\n  \"collections\": " + Model.TotalCollections + "\n}"
        : preview.Body;

    var lastRunText = Model.LastRunAt.HasValue
        ? Model.LastRunAt.Value.ToLocalTime().ToString("g")
        : "Never";
    var statusText = Model.LastStatusCode.HasValue
        ? $"{Model.LastStatusCode} {(Model.LastRunSucceeded ? "OK" : "response")}"
        : "No runs yet";
    var statusClass = Model.LastRunSucceeded ? "success" : "warn";
}

<section class="dashboard-hero">
    <div class="hero-copy">
        <p class="hero-kicker">Workspace Command Center</p>
        <h1>Test API flows without switching between tools.</h1>
        <p class="hero-subtext">
            A unified dashboard for workspaces, collections, requests, and environments. Get a fast overview of everything that matters before sending the next request.
        </p>
        <div class="hero-actions">
            <a class="btn app-btn app-btn-primary" asp-area="" asp-controller="RequestBuilder" asp-action="Index">Open Request Builder</a>
            <a class="btn app-btn app-btn-muted" asp-area="" asp-controller="Request" asp-action="Index">Browse Requests</a>
        </div>
    </div>

    <div class="hero-console" aria-label="API execution preview">
        <div class="console-head">
            <span></span><span></span><span></span>
        </div>
        <p><strong>@(preview?.Method.ToString().ToUpperInvariant() ?? "GET")</strong> @previewPath</p>
        <pre>@previewBody</pre>
        <p class="console-status @statusClass">@statusText@(Model.LastDurationMs.HasValue ? $" in {Model.LastDurationMs} ms" : string.Empty)</p>
    </div>
</section>

<div class="modal fade" id="workspaceDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content collection-modal">
            <div class="modal-header collection-modal-header">
                <h5 class="modal-title">Workspace Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body collection-modal-body">Loading...</div>
        </div>
    </div>
</div>

<section class="stats-grid" aria-label="Quick stats">
    <article class="stat-card">
        <p>Total Workspaces</p>
        <h2>@Model.TotalWorkspaces.ToString("00")</h2>
        <span>+@Model.RecentWorkspaces this week</span>
        <a class="entity-link" asp-area="" asp-controller="Workspaces" asp-action="Index">Open Workspaces</a>
    </article>
    <article class="stat-card">
        <p>Active Collections</p>
        <h2>@Model.TotalCollections.ToString("00")</h2>
        <span>@Model.TotalRequests requests mapped</span>
        <a class="entity-link" asp-area="" asp-controller="Collection" asp-action="Index">Open Collections</a>
    </article>
    <article class="stat-card">
        <p>Total Requests</p>
        <h2>@Model.TotalRequests.ToString("00")</h2>
        <span>Last run: @lastRunText</span>
        <a class="entity-link" asp-area="" asp-controller="Request" asp-action="Index">Open Requests</a>
    </article>
    <article class="stat-card">
        <p>Active Environment</p>
        <h2>@(Model.ActiveEnvironment?.Name ?? "None")</h2>
        <span>@(Model.ActiveEnvironment == null ? "No active environment" : $"{Model.ActiveEnvironment.VariableCount} variables loaded")</span>
        <a class="entity-link" asp-area="" asp-controller="Environment" asp-action="Index">Open Environments</a>
    </article>
</section>

<section class="dashboard-flow" aria-label="Main navigation flow">
    <article class="flow-card">
        <p class="flow-step">01</p>
        <h3>Workspaces</h3>
        <p>Choose the team context and the API domain you want to test.</p>
        <a asp-area="" asp-controller="Workspaces" asp-action="Index">Open Workspaces</a>
    </article>
    <article class="flow-card">
        <p class="flow-step">02</p>
        <h3>Collections</h3>
        <p>Review endpoint groups and mapped scenarios by workspace.</p>
        <a asp-area="" asp-controller="Collection" asp-action="Index">Go to Collections</a>
    </article>
    <article class="flow-card">
        <p class="flow-step">03</p>
        <h3>Requests</h3>
        <p>Filter requests by method, tags, and latest status.</p>
        <a asp-area="" asp-controller="Request" asp-action="Index">Open Request List</a>
    </article>
    <article class="flow-card">
        <p class="flow-step">04</p>
        <h3>Request Builder</h3>
        <p>Compose the payload, choose an environment, and run the call immediately.</p>
        <a asp-area="" asp-controller="RequestBuilder" asp-action="Index">Launch Builder</a>
    </article>
</section>

<section class="dashboard-grid">
    <article class="dashboard-panel">
        <div class="panel-title-row">
            <h3>Workspaces</h3>
            <a asp-area="" asp-controller="Workspaces" asp-action="Index">View all</a>
        </div>
        <ul class="panel-list">
            @if (Model.Workspaces.Count == 0)
            {
                <li>
                    <strong>No workspaces yet</strong>
                    <span>Create a workspace to start organizing requests.</span>
                    <a class="entity-link" asp-area="" asp-controller="Workspaces" asp-action="Index">Open Workspaces</a>
                </li>
            }
            else
            {
                @foreach (var workspace in Model.Workspaces)
                {
                    <li>
                        <strong>@workspace.Name</strong>
                        <span>@workspace.CollectionCount collections · @workspace.RequestCount requests</span>
                        <a href="#" class="entity-link open-workspace-details" data-workspace-id="@workspace.Id">Workspace Details</a>
                    </li>
                }
            }
        </ul>
    </article>

    <article class="dashboard-panel">
        <div class="panel-title-row">
            <h3>Collections</h3>
            <a asp-area="" asp-controller="Collection" asp-action="Index">Open catalog</a>
        </div>
        <ul class="panel-list mono">
            @if (Model.Collections.Count == 0)
            {
                <li>
                    <strong>No collections yet</strong>
                    <span>Add collections to group requests.</span>
                    <a class="entity-link" asp-area="" asp-controller="Collection" asp-action="Index">Open Collections</a>
                </li>
            }
            else
            {
                @foreach (var collection in Model.Collections)
                {
                    var methodText = collection.Methods.Count == 0
                        ? $"{collection.RequestCount} requests"
                        : string.Join(", ", collection.Methods.Select(method => method.ToString().ToUpperInvariant()));
                    <li>
                        <strong>@collection.Name</strong>
                        <span>@methodText</span>
                        <a class="entity-link" asp-area="" asp-controller="Collection" asp-action="Details" asp-route-id="@collection.Id">Collection Details</a>
                    </li>
                }
            }
        </ul>
    </article>

    <article class="dashboard-panel">
        <div class="panel-title-row">
            <h3>Quick Actions</h3>
            <a asp-area="" asp-controller="RequestBuilder" asp-action="Index">Runner</a>
        </div>
        <div class="quick-actions">
            <a asp-area="" asp-controller="Workspaces" asp-action="Index">+ Open workspaces</a>
            <a asp-area="" asp-controller="Collection" asp-action="Index">+ Open collections</a>
            <a asp-area="" asp-controller="Request" asp-action="Index">+ Open requests</a>
            <a asp-area="" asp-controller="RequestBuilder" asp-action="Index">+ New request in builder</a>
        </div>
    </article>

    <article class="dashboard-panel">
        <div class="panel-title-row">
            <h3>Active Environment</h3>
            <a asp-area="" asp-controller="RequestBuilder" asp-action="Index">Switch in builder</a>
        </div>
        <div class="env-box">
            @if (Model.ActiveEnvironment == null)
            {
                <p><span>Name</span><strong>None</strong></p>
                <p><span>Base URL</span><strong>No environment configured</strong></p>
                <p><span>Variables</span><strong>0 loaded</strong></p>
                <p><span>Secrets</span><strong>0 secured</strong></p>
            }
            else
            {
                <p><span>Name</span><strong>@Model.ActiveEnvironment.Name</strong></p>
                <p><span>Base URL</span><strong>@Model.ActiveEnvironment.BaseUrl</strong></p>
                <p><span>Variables</span><strong>@Model.ActiveEnvironment.VariableCount loaded</strong></p>
                <p><span>Secrets</span><strong>@Model.ActiveEnvironment.SecretCount secured</strong></p>
            }
        </div>
        <a class="entity-link" asp-area="" asp-controller="Environment" asp-action="Index">Environment Details</a>
    </article>
</section>

@section Scripts {
    <script>
        $(function () {
            $('.open-workspace-details').on('click', function (e) {
                e.preventDefault();
                var id = $(this).data('workspace-id');
                var url = '/workspace-details' + (id ? ('?workspaceId=' + id) : '');
                $.get(url, function (html) {
                    if (window.injectModalHtml) window.injectModalHtml('#workspaceDetailsModal .modal-body', html);
                    else {
                        $('#workspaceDetailsModal .modal-body').html(html);
                        var modalEl = document.getElementById('workspaceDetailsModal');
                        if (modalEl && window.bootstrap) {
                            var modal = new bootstrap.Modal(modalEl);
                            modal.show();
                        }
                    }
                }).fail(function () {
                    alert('Failed to load workspace details');
                });
            });
        });
    </script>
}
