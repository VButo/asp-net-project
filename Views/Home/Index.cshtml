@{
    ViewData["Title"] = "Dashboard";
}

<section class="dashboard-hero">
    <div class="hero-copy">
        <p class="hero-kicker">Workspace Command Center</p>
        <h1>Testiraj API flow bez prebacivanja izmedu alata.</h1>
        <p class="hero-subtext">
            Jedinstveni dashboard za workspaceove, kolekcije, requestove i environmente. Brz pregled svega sto je bitno prije slanja iduceg requesta.
        </p>
        <div class="hero-actions">
            <a class="btn app-btn app-btn-primary" asp-area="" asp-controller="Home" asp-action="RequestBuilder">Open Request Builder</a>
            <a class="btn app-btn app-btn-muted" asp-area="" asp-controller="Home" asp-action="Requests">Browse Requests</a>
        </div>
    </div>

    <div class="hero-console" aria-label="API execution preview">
        <div class="console-head">
            <span></span><span></span><span></span>
        </div>
        <p><strong>POST</strong> /v1/payments/authorize</p>
        <pre>{
  "amount": 129.90,
  "currency": "EUR",
  "customerId": "cus_239A"
}</pre>
        <p class="console-status success">200 OK in 143 ms</p>
    </div>
</section>

<section class="stats-grid" aria-label="Quick stats">
    <article class="stat-card">
        <p>Total Workspaceova</p>
        <h2>07</h2>
        <span>+2 ovaj tjedan</span>
        <a class="entity-link" asp-area="" asp-controller="Home" asp-action="Privacy">Open Workspaces</a>
    </article>
    <article class="stat-card">
        <p>Aktivne Collectione</p>
        <h2>19</h2>
        <span>132 requesta mapirano</span>
        <a class="entity-link" asp-area="" asp-controller="Home" asp-action="Collections">Open Collections</a>
    </article>
    <article class="stat-card">
        <p>Ukupno Requestova</p>
        <h2>246</h2>
        <span>Last run: prije 2 min</span>
        <a class="entity-link" asp-area="" asp-controller="Home" asp-action="Requests">Open Requests</a>
    </article>
    <article class="stat-card">
        <p>Aktivni Environment</p>
        <h2>staging-eu</h2>
        <span>token validan jos 41 min</span>
        <a class="entity-link" asp-area="" asp-controller="Home" asp-action="Environments">Open Environments</a>
    </article>
</section>

<section class="dashboard-flow" aria-label="Main navigation flow">
    <article class="flow-card">
        <p class="flow-step">01</p>
        <h3>Workspaces</h3>
        <p>Odaberi timski kontekst i domenu API-ja koju testiras.</p>
        <a asp-area="" asp-controller="Home" asp-action="Privacy">Open Workspaces</a>
    </article>
    <article class="flow-card">
        <p class="flow-step">02</p>
        <h3>Collections</h3>
        <p>Pregledaj endpoint grupe i mapirane scenarije po workspaceu.</p>
        <a asp-area="" asp-controller="Home" asp-action="Collections">Go to Collections</a>
    </article>
    <article class="flow-card">
        <p class="flow-step">03</p>
        <h3>Requests</h3>
        <p>Filtriraj requestove po metodi, tagovima i zadnjem statusu.</p>
        <a asp-area="" asp-controller="Home" asp-action="Requests">Open Request List</a>
    </article>
    <article class="flow-card">
        <p class="flow-step">04</p>
        <h3>Request Builder</h3>
        <p>Sastavi payload, odaberi environment i odmah pokreni poziv.</p>
        <a asp-area="" asp-controller="Home" asp-action="RequestBuilder">Launch Builder</a>
    </article>
</section>

<section class="dashboard-grid">
    <article class="dashboard-panel">
        <div class="panel-title-row">
            <h3>Workspaceovi</h3>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">View all</a>
        </div>
        <ul class="panel-list">
            <li>
                <strong>Payments Core</strong>
                <span>6 collectiona · 48 requestova</span>
                <a class="entity-link" asp-area="" asp-controller="Home" asp-action="WorkspaceDetails">Workspace Details</a>
            </li>
            <li>
                <strong>Identity Gateway</strong>
                <span>4 collectiona · 32 requesta</span>
                <a class="entity-link" asp-area="" asp-controller="Home" asp-action="WorkspaceDetails">Workspace Details</a>
            </li>
            <li>
                <strong>Billing Public API</strong>
                <span>3 collectiona · 27 requestova</span>
                <a class="entity-link" asp-area="" asp-controller="Home" asp-action="WorkspaceDetails">Workspace Details</a>
            </li>
        </ul>
    </article>

    <article class="dashboard-panel">
        <div class="panel-title-row">
            <h3>Collectione</h3>
            <a asp-area="" asp-controller="Home" asp-action="Collections">Open catalog</a>
        </div>
        <ul class="panel-list mono">
            <li><strong>Auth / Sessions</strong><span>GET, POST, DELETE</span><a class="entity-link" asp-area="" asp-controller="Home" asp-action="CollectionDetails">Collection Details</a></li>
            <li><strong>Transactions</strong><span>POST, PATCH, GET</span><a class="entity-link" asp-area="" asp-controller="Home" asp-action="CollectionDetails">Collection Details</a></li>
            <li><strong>Webhooks</strong><span>POST test payloads</span><a class="entity-link" asp-area="" asp-controller="Home" asp-action="CollectionDetails">Collection Details</a></li>
            <li><strong>Health Checks</strong><span>GET /ready, /live</span><a class="entity-link" asp-area="" asp-controller="Home" asp-action="CollectionDetails">Collection Details</a></li>
        </ul>
    </article>

    <article class="dashboard-panel">
        <div class="panel-title-row">
            <h3>Brze Akcije</h3>
            <a asp-area="" asp-controller="Home" asp-action="RequestBuilder">Runner</a>
        </div>
        <div class="quick-actions">
            <a asp-area="" asp-controller="Home" asp-action="Privacy">+ Open workspaces</a>
            <a asp-area="" asp-controller="Home" asp-action="Collections">+ Open collections</a>
            <a asp-area="" asp-controller="Home" asp-action="Requests">+ Open requests</a>
            <a asp-area="" asp-controller="Home" asp-action="RequestBuilder">+ New request in builder</a>
        </div>
    </article>

    <article class="dashboard-panel">
        <div class="panel-title-row">
            <h3>Aktivni Environment</h3>
            <a asp-area="" asp-controller="Home" asp-action="RequestBuilder">Switch in builder</a>
        </div>
        <div class="env-box">
            <p><span>Name</span><strong>staging-eu</strong></p>
            <p><span>Base URL</span><strong>https://staging.api.company.com</strong></p>
            <p><span>Variables</span><strong>14 loaded</strong></p>
            <p><span>Secrets</span><strong>3 secured</strong></p>
        </div>
        <a class="entity-link" asp-area="" asp-controller="Home" asp-action="Environments">Environment Details</a>
    </article>
</section>
