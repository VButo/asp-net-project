@{
    ViewData["Title"] = "Workspace Details";
}

<nav class="page-crumbs" aria-label="Breadcrumb">
    <a asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-area="" asp-controller="Home" asp-action="Privacy">Workspaces</a>
    <span>/</span>
    <strong>Workspace Details</strong>
</nav>

<section class="details-hero">
    <div>
        <p class="details-kicker">Workspace Details</p>
        <h1>Payments Core</h1>
        <p>Centralni workspace za payment autorizaciju, refund, settlement i antifraud request tokove.</p>
    </div>
    <div class="details-hero-actions">
        <a class="btn app-btn app-btn-primary" asp-area="" asp-controller="Home" asp-action="Collections">Open Collections</a>
        <a class="btn app-btn app-btn-muted" asp-area="" asp-controller="Home" asp-action="Environments">Open Environments</a>
    </div>
</section>

<section class="details-grid">
    <article class="detail-panel">
        <div class="panel-title-row">
            <h3>Povezane Collectione</h3>
            <a asp-area="" asp-controller="Home" asp-action="Collections">View all</a>
        </div>
        <ul class="panel-list mono">
            <li><strong>Payments Authorization</strong><span>18 requestova</span><a class="entity-link" asp-area="" asp-controller="Home" asp-action="CollectionDetails">Open Collection Details</a></li>
            <li><strong>Transactions Core</strong><span>14 requestova</span><a class="entity-link" asp-area="" asp-controller="Home" asp-action="CollectionDetails">Open Collection Details</a></li>
            <li><strong>Refund Handling</strong><span>9 requestova</span><a class="entity-link" asp-area="" asp-controller="Home" asp-action="CollectionDetails">Open Collection Details</a></li>
        </ul>
    </article>

    <article class="detail-panel">
        <div class="panel-title-row">
            <h3>Povezani Environmenti</h3>
            <a asp-area="" asp-controller="Home" asp-action="Environments">Manage</a>
        </div>
        <ul class="panel-list mono">
            <li><strong>staging-eu</strong><span>Base URL: https://staging.api.company.com</span><a class="entity-link" asp-area="" asp-controller="Home" asp-action="RequestBuilder">Open in Builder</a></li>
            <li><strong>staging-us</strong><span>Base URL: https://us-staging.api.company.com</span><a class="entity-link" asp-area="" asp-controller="Home" asp-action="RequestBuilder">Open in Builder</a></li>
            <li><strong>prod-readonly</strong><span>Read-only smoke endpointi</span><a class="entity-link" asp-area="" asp-controller="Home" asp-action="RequestBuilder">Open in Builder</a></li>
        </ul>
    </article>
</section>
