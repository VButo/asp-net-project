@{
    ViewData["Title"] = "Request Builder";
}

<nav class="page-crumbs" aria-label="Breadcrumb">
    <a asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-area="" asp-controller="Home" asp-action="Privacy">Workspaces</a>
    <span>/</span>
    <a asp-area="" asp-controller="Home" asp-action="Collections">Collections</a>
    <span>/</span>
    <a asp-area="" asp-controller="Home" asp-action="Requests">Requests</a>
    <span>/</span>
    <strong>Request Builder</strong>
</nav>

<section class="runner-hero" aria-label="Request builder intro">
    <div class="runner-hero-copy">
        <p class="runner-kicker">Request Builder / Runner</p>
        <h1>Konfiguriraj, pokreni i analiziraj API pozive iz jednog tehnickog cockpit pogleda.</h1>
        <p>Glavni ekran za endpoint testiranje: metoda, URL, headers, body, environment i response panel bez prebacivanja izmedu stranica.</p>
    </div>
    <div class="runner-hero-stats">
        <p><span>Current Environment</span><strong>staging-eu</strong></p>
        <p><span>Last Execution</span><strong>202 Accepted · 121 ms</strong></p>
        <p><span>Open Request</span><strong><a asp-area="" asp-controller="Home" asp-action="RequestDetails">POST /v1/notifications/dispatch</a></strong></p>
    </div>
</section>

<section class="runner-layout" aria-label="Request runner workspace">
    <div class="runner-left-panel">
        <section class="runner-request-head" aria-label="HTTP request setup">
            <div class="runner-method-url">
                <label class="runner-field">
                    <span>Method</span>
                    <select>
                        <option selected>POST</option>
                        <option>GET</option>
                        <option>PUT</option>
                        <option>PATCH</option>
                        <option>DELETE</option>
                    </select>
                </label>
                <label class="runner-field runner-url-field">
                    <span>Request URL</span>
                    <input type="text" value="https://staging.api.company.com/v1/notifications/dispatch" />
                </label>
            </div>

            <div class="runner-controls-row">
                <label class="runner-field runner-env-field">
                    <span>Environment</span>
                    <select>
                        <option selected>staging-eu</option>
                        <option>staging-us</option>
                        <option>prod-readonly</option>
                        <option>local-dev</option>
                    </select>
                </label>
                <button type="button" class="runner-send-btn">Send</button>
            </div>
            <div class="runner-jump-links">
                <a asp-area="" asp-controller="Home" asp-action="Environments">Manage Environments</a>
                <a asp-area="" asp-controller="Home" asp-action="RequestDetails">Back to Request Details</a>
            </div>
        </section>

        <section class="runner-editor-panel" aria-label="Request editors">
            <div class="runner-tab-strip">
                <button type="button" class="runner-tab active">Headers</button>
                <button type="button" class="runner-tab">Body</button>
                <button type="button" class="runner-tab">Auth</button>
                <button type="button" class="runner-tab">Tests</button>
            </div>

            <div class="runner-editors">
                <article class="editor-card">
                    <header>
                        <h2>Headers</h2>
                        <span>4 active</span>
                    </header>
                    <div class="kv-list">
                        <div><span>Content-Type</span><strong>application/json</strong></div>
                        <div><span>Authorization</span><strong>Bearer {{access_token}}</strong></div>
                        <div><span>X-Correlation-Id</span><strong>{{trace_id}}</strong></div>
                        <div><span>X-Channel</span><strong>web-checkout</strong></div>
                    </div>
                </article>

                <article class="editor-card body-card">
                    <header>
                        <h2>Body (JSON)</h2>
                        <span>raw</span>
                    </header>
                    <pre>{
  "template": "payment-received",
  "locale": "hr-HR",
  "recipient": {
    "email": "user@example.com",
    "name": "Ivan Horvat"
  },
  "payload": {
    "paymentId": "pay_99231",
    "amount": 129.90,
    "currency": "EUR"
  }
}</pre>
                </article>
            </div>
        </section>
    </div>

    <aside class="runner-right-panel" aria-label="Execution response">
        <div class="response-head">
            <h2>Response</h2>
            <p class="response-status success">202 Accepted · 121 ms · 1.3 KB</p>
        </div>

        <div class="response-meta">
            <p><span>Collection</span><strong><a asp-area="" asp-controller="Home" asp-action="CollectionDetails">Notification Dispatch</a></strong></p>
            <p><span>Request</span><strong><a asp-area="" asp-controller="Home" asp-action="RequestDetails">POST /v1/notifications/dispatch</a></strong></p>
            <p><span>Executed At</span><strong>Today, 15:42:09</strong></p>
        </div>

        <div class="response-tabs">
            <button type="button" class="response-tab active">Body</button>
            <button type="button" class="response-tab">Headers</button>
            <button type="button" class="response-tab">Timeline</button>
        </div>

        <pre class="response-body">{
  "status": "queued",
  "messageId": "msg_43f9121",
  "channel": "email",
  "delivery": {
    "provider": "mailgun",
    "estimatedIn": "2s"
  },
  "meta": {
    "requestId": "req_aa12b9",
    "traceId": "tr_22f991"
  }
}</pre>

        <div class="runner-footer-links">
            <a asp-area="" asp-controller="Home" asp-action="RequestDetails">Open Full Response Context</a>
            <a asp-area="" asp-controller="Home" asp-action="CollectionDetails">Back to Collection</a>
            <a asp-area="" asp-controller="Home" asp-action="WorkspaceDetails">Back to Workspace</a>
        </div>
    </aside>
</section>
