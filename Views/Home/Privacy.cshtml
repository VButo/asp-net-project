@{
    ViewData["Title"] = "Workspaces";
}

<nav class="page-crumbs" aria-label="Breadcrumb">
    <a asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <strong>Workspaces</strong>
</nav>

<section class="workspaces-hero">
    <div class="workspaces-hero-copy">
        <p class="workspaces-kicker">Workspace Registry</p>
        <h1>Organiziraj API domene kao timske radne prostore.</h1>
        <p>
            Pregledaj sve workspaceove s vlasnistvom i strukturom. Svaka kartica odmah pokazuje tko je owner i koliko ima collectiona i environmenta.
        </p>
    </div>
    <div class="workspaces-hero-actions">
        <a class="btn app-btn app-btn-primary" asp-area="" asp-controller="Home" asp-action="WorkspaceDetails">+ Novi Workspace</a>
        <a class="btn app-btn app-btn-muted" asp-area="" asp-controller="Home" asp-action="Collections">Import Workspace</a>
    </div>
</section>

<section class="workspaces-toolbar" aria-label="Workspace filters">
    <div class="workspace-search">
        <label for="workspaceSearch">Pretraga</label>
        <input id="workspaceSearch" type="text" value="" placeholder="Search by name, owner or tag" />
    </div>
    <div class="workspace-filter-group">
        <button class="filter-chip active" type="button">Svi</button>
        <button class="filter-chip" type="button">My Team</button>
        <button class="filter-chip" type="button">Production</button>
        <button class="filter-chip" type="button">Sandbox</button>
    </div>
</section>

<section class="workspaces-grid" aria-label="Workspace list">
    <article class="workspace-card">
        <div class="workspace-head">
            <h2>Payments Core</h2>
            <span class="workspace-owner">Owner: Vedran T.</span>
        </div>
        <p class="workspace-description">Glavni workspace za payment flow, autorizaciju, refund i settlement endpointove.</p>
        <div class="workspace-metrics">
            <p><span>Collectiona</span><strong>6</strong></p>
            <p><span>Environmenta</span><strong>3</strong></p>
        </div>
        <a class="entity-link" asp-area="" asp-controller="Home" asp-action="WorkspaceDetails">Open Workspace Details</a>
    </article>

    <article class="workspace-card">
        <div class="workspace-head">
            <h2>Identity Gateway</h2>
            <span class="workspace-owner">Owner: Ana R.</span>
        </div>
        <p class="workspace-description">Auth, token lifecycle i session endpointovi za web i mobile klijente.</p>
        <div class="workspace-metrics">
            <p><span>Collectiona</span><strong>4</strong></p>
            <p><span>Environmenta</span><strong>2</strong></p>
        </div>
        <a class="entity-link" asp-area="" asp-controller="Home" asp-action="WorkspaceDetails">Open Workspace Details</a>
    </article>

    <article class="workspace-card">
        <div class="workspace-head">
            <h2>Orders Public API</h2>
            <span class="workspace-owner">Owner: Marko S.</span>
        </div>
        <p class="workspace-description">Order create/update/status endpointovi za partnere i javne integracije.</p>
        <div class="workspace-metrics">
            <p><span>Collectiona</span><strong>5</strong></p>
            <p><span>Environmenta</span><strong>4</strong></p>
        </div>
        <a class="entity-link" asp-area="" asp-controller="Home" asp-action="WorkspaceDetails">Open Workspace Details</a>
    </article>

    <article class="workspace-card">
        <div class="workspace-head">
            <h2>Notifications Hub</h2>
            <span class="workspace-owner">Owner: Petra K.</span>
        </div>
        <p class="workspace-description">Email/SMS/push delivery endpointovi i webhook callback test scenariji.</p>
        <div class="workspace-metrics">
            <p><span>Collectiona</span><strong>3</strong></p>
            <p><span>Environmenta</span><strong>2</strong></p>
        </div>
        <a class="entity-link" asp-area="" asp-controller="Home" asp-action="WorkspaceDetails">Open Workspace Details</a>
    </article>

    <article class="workspace-card">
        <div class="workspace-head">
            <h2>Fraud Engine</h2>
            <span class="workspace-owner">Owner: Luka M.</span>
        </div>
        <p class="workspace-description">Risk scoring, blacklist checks i event stream endpointovi za anti-fraud pipeline.</p>
        <div class="workspace-metrics">
            <p><span>Collectiona</span><strong>7</strong></p>
            <p><span>Environmenta</span><strong>3</strong></p>
        </div>
        <a class="entity-link" asp-area="" asp-controller="Home" asp-action="WorkspaceDetails">Open Workspace Details</a>
    </article>

    <article class="workspace-card">
        <div class="workspace-head">
            <h2>Developer Sandbox</h2>
            <span class="workspace-owner">Owner: Team API Platform</span>
        </div>
        <p class="workspace-description">Siguran prostor za prototipiranje novih ruta i test payloadova prije mergea.</p>
        <div class="workspace-metrics">
            <p><span>Collectiona</span><strong>8</strong></p>
            <p><span>Environmenta</span><strong>5</strong></p>
        </div>
        <a class="entity-link" asp-area="" asp-controller="Home" asp-action="WorkspaceDetails">Open Workspace Details</a>
    </article>
</section>
