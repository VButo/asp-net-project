@model List<ApiCollection>

@{
    ViewData["Title"] = ViewData["Title"] ?? "Collections";
    var breadcrumbCurrent = ViewData["BreadcrumbCurrent"] as string ?? "Collections";
    var heroKicker = ViewData["HeroKicker"] as string ?? string.Empty;
    var heroTitle = ViewData["HeroTitle"] as string ?? string.Empty;
    var heroDescription = ViewData["HeroDescription"] as string ?? string.Empty;
    var newCollectionActionText = ViewData["NewCollectionActionText"] as string ?? string.Empty;
    var importCollectionActionText = ViewData["ImportCollectionActionText"] as string ?? string.Empty;
    var searchPlaceholder = ViewData["SearchPlaceholder"] as string ?? string.Empty;
    var filters = ViewData["Filters"] as List<string> ?? new List<string>();
}

<nav class="page-crumbs" aria-label="Breadcrumb">
    <a asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
    <span>/</span>
    <a asp-area="" asp-controller="Workspaces" asp-action="Index">Workspaces</a>
    <span>/</span>
    <strong>@breadcrumbCurrent</strong>
</nav>

<section class="collections-hero">
    <div class="collections-hero-copy">
        <p class="collections-kicker">@heroKicker</p>
        <h1>@heroTitle</h1>
        <p>@heroDescription</p>
    </div>
    <div class="collections-hero-actions">
        <a class="btn app-btn app-btn-primary" asp-area="" asp-controller="Collection" asp-action="Details">@newCollectionActionText</a>
        <a class="btn app-btn app-btn-muted" asp-area="" asp-controller="Request" asp-action="Index">@importCollectionActionText</a>
    </div>
</section>

<section class="collections-toolbar" aria-label="Collection filters">
    <div class="collection-search">
        <label for="collectionSearch">Search</label>
        <input id="collectionSearch" type="text" value="" placeholder="@searchPlaceholder" />
    </div>
    <div class="collection-filter-group">
        @foreach (var filter in filters.Select((value, index) => new { value, index }))
        {
            <button class="filter-chip @(filter.index == 0 ? "active" : string.Empty)" type="button">@filter.value</button>
        }
    </div>
</section>

<section class="collections-grid" aria-label="Collections list">
    @foreach (var collection in Model)
    {
        <article class="collection-card">
            <div class="collection-head">
                <h2>@collection.Name</h2>
                <span class="collection-badge">@(collection.IsShared ? "Shared" : "Private")</span>
            </div>
            <p class="collection-description">@collection.Description</p>
            <div class="collection-meta">
                <p><span>Workspace</span><strong>@(collection.Workspace?.Name ?? string.Empty)</strong></p>
                <p><span>Requests</span><strong>@collection.Requests.Count</strong></p>
            </div>
            <a class="entity-link" asp-area="" asp-controller="Collection" asp-action="Details" asp-route-id="@collection.Id">Open Collection Details</a>
        </article>
    }
</section>