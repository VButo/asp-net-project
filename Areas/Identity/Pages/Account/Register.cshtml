@page
@model API_tester.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="auth-panel">
    <div class="auth-card">
        <p class="auth-kicker">Account</p>
        <h1>Register</h1>
        <form id="registerForm" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <label class="runner-field" asp-for="Input.Email">
                <span>Email</span>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </label>
            <label class="runner-field" asp-for="Input.OIB">
                <span>OIB</span>
                <input asp-for="Input.OIB" class="form-control" inputmode="numeric" maxlength="11" />
                <span asp-validation-for="Input.OIB" class="text-danger"></span>
            </label>
            <label class="runner-field" asp-for="Input.JMBG">
                <span>JMBG</span>
                <input asp-for="Input.JMBG" class="form-control" inputmode="numeric" maxlength="13" />
                <span asp-validation-for="Input.JMBG" class="text-danger"></span>
            </label>
            <label class="runner-field" asp-for="Input.Password">
                <span>Password</span>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </label>
            <label class="runner-field" asp-for="Input.ConfirmPassword">
                <span>Confirm Password</span>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </label>
            <button id="registerSubmit" type="submit" class="runner-send-btn">Register</button>
        </form>

        @if (Model.ExternalLogins.Count > 0)
        {
            <form class="auth-external" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                @foreach (var provider in Model.ExternalLogins)
                {
                    <button type="submit" class="btn app-btn app-btn-muted" name="provider" value="@provider.Name">
                        Continue with @provider.DisplayName
                    </button>
                }
            </form>
        }
    </div>
</section>

<partial name="_ValidationScriptsPartial" />
