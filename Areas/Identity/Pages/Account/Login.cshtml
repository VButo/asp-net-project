@page "/login"
@model API_tester.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log in";
}

<section class="auth-panel">
    <div class="auth-card">
        <p class="auth-kicker">Welcome Back</p>
        <h1>Log in</h1>
        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <label class="runner-field" asp-for="Input.Email">
                <span>Email</span>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </label>
            <label class="runner-field" asp-for="Input.Password">
                <span>Password</span>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </label>
            <label class="auth-check" asp-for="Input.RememberMe">
                <input asp-for="Input.RememberMe" />
                <span>Remember me</span>
            </label>
            <button id="login-submit" type="submit" class="runner-send-btn">Log in</button>
        </form>

        @if (Model.ExternalLogins.Count > 0)
        {
            <form class="auth-external" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                @foreach (var provider in Model.ExternalLogins)
                {
                    <button type="submit" class="btn app-btn app-btn-muted" name="provider" value="@provider.Name">
                        Continue with @provider.DisplayName
                    </button>
                }
            </form>
        }

        <div class="auth-links">
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a>
        </div>
    </div>
</section>

<partial name="_ValidationScriptsPartial" />
